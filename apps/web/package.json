{
  "name": "@operalibre/web",
  "private": true,
  "license": "SEE LICENSE IN ../../LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "android:sync": "npm run build && cap sync android",
    "android:open": "npm run android:sync && cap open android",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "npm run ios:sync && cap open ios",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capawesome/capacitor-file-picker": "^8.0.3",
    "epubjs": "^0.3.93",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.4.3"
  }
}
