{
  "name": "operalibre",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node script/dev.mjs",
    "dev:server": "cargo run --manifest-path apps/server/Cargo.toml",
    "dev:web": "npm run dev -w @operalibre/web",
    "build": "cargo build --manifest-path apps/server/Cargo.toml && npm run build -w @operalibre/web",
    "build:ios": "./script/build_ios.sh",
    "sync:ios": "npm run ios:sync -w @operalibre/web",
    "typecheck": "cargo check --manifest-path apps/server/Cargo.toml && npm run typecheck -w @operalibre/web"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.10"
  }
}
