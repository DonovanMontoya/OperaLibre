# OperaLibre server settings.
# Copy this file to server.config and adjust the paths for your machine.

# Network binding.
host = 0.0.0.0
port = 4000

# Comma-separated list of origins allowed to make cross-origin (CORS)
# requests, e.g. https://books.example.com, http://192.168.1.20:5173
# Leave blank to reflect any requesting origin (development default).
allowed_origins =

# Folder containing your audiobook files.
# Relative paths are resolved from this config file's directory.
library_root = /path/to/audiobooks

# Server data files.
data_dir = data
progress_file = data/progress.json
users_file = data/users.json

# Serve the built web app from this server (single-origin deployment).
# Point at the folder produced by `npm run build`, e.g. apps/web/dist.
# Leave blank if a reverse proxy or the Vite dev server hosts the frontend.
web_dist_dir =

# Optional Libation / Audible import.
# Leave these blank unless you use Libation.
libation_cli_path =
libation_files_dir =

# Optional readalong sync generation (sentence highlighting).
# Path to the echogarden CLI (npm install -g echogarden). Leave blank to
# look for `echogarden` on PATH; if it isn't found, sync generation is
# simply disabled and user-provided .sync.json sidecars still work.
alignment_cli_path =
