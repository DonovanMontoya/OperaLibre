# OperaLibre release settings.
#
# This package stores its library and data beside the server executable.
# You can replace these with absolute paths at any time.

host = 0.0.0.0
port = 4000
allowed_origins =

library_root = audiobooks
data_dir = data
progress_file = data/progress.json
users_file = data/users.json

# The server-only package does not include the web app.
web_dist_dir =

# Optional Libation / Audible import.
libation_cli_path =
libation_files_dir =

# Optional readalong sentence synchronization.
alignment_cli_path =
